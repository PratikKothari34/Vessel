# ── Scenario_Chat backend configuration ──────────────────────────────────
# Copy to ".env" and fill in. The app runs LOCAL-ONLY if the TURSO_* vars are
# left blank — cloud sync is opt-in.

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
# CORS allow-list. Vite dev server origin; packaged Electron sends no Origin.
ALLOWED_ORIGINS=http://localhost:5173

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Chat model built from the Modelfile (ollama create scenario-chat -f Modelfile)
OLLAMA_MODEL=scenario-chat
# Librarian model that condenses old turns into the rolling summary.
SUMMARIZER_MODEL=gemma3:4b
# Small context for the summarizer so reasoning models don't allocate a huge KV cache.
SUMMARIZER_NUM_CTX=8192
# Embedding model for retrieval (produces 768-dim vectors).
EMBED_MODEL=nomic-embed-text
# Embedder GPU layers: 0 = CPU (faster load, frees VRAM), -1 = let Ollama decide.
EMBED_NUM_GPU=0

# ── Turso / libSQL ────────────────────────────────────────────────────────
# Local-first DB file (embedded replica). Always used.
LOCAL_DB_PATH=./data/scenario.db
# Leave BOTH blank for local-only mode. Fill in to enable cloud backup/sync.
TURSO_DATABASE_URL=
# Optional: the auth token is normally stored in the OS keychain. If set here on
# first run it's migrated into the keychain automatically; afterwards .env isn't
# needed for it. Leave blank to use the keychain only.
TURSO_AUTH_TOKEN=

# ── Encryption at rest ──────────────────────────────────────────────────────
# The local DB is encrypted with a 256-bit key kept in the OS keychain (Windows
# Credential Manager), generated automatically on first run. You normally leave
# this BLANK. Set it only to bring your own key (e.g. to share a DB across
# machines without sync). WARNING: changing/removing the key for an existing
# encrypted DB makes it unreadable.
DB_ENCRYPTION_KEY=
# Background sync cadence (seconds). 0 = sync only on startup/shutdown.
TURSO_SYNC_INTERVAL=60

# ── Memory tuning ─────────────────────────────────────────────────────────
# Recent turns always kept verbatim in the live window.
VERBATIM_TURNS=8
# When verbatim exceeds this, fold the oldest into the summary + archive.
SUMMARIZE_THRESHOLD=12
# Max archived turns retrieval may inject per request.
RETRIEVE_K=4
# Min cosine similarity (0-1) for a retrieved turn to count as relevant.
RETRIEVE_MIN_SCORE=0.45
# Hard cap on rolling-summary length (chars).
MAX_SUMMARY_CHARS=6000
# Per-conversation lock timeout (ms) so a wedged turn can't block future turns.
LOCK_WAIT_MS=120000
