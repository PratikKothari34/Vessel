# Dependencies
node_modules/
app/node_modules/

# Env / secrets (Turso URL + auth token live here)
.env
.env.local
app/.env

# Local Turso database + sync engine sidecar files (scenario.db-info, -wal, etc)
*.db
*.db-*
*.sqlite
*.sqlite3
data/

# Build output
out/
dist/
app/out/
app/dist/

# Generated icon artifacts. icon.ico IS tracked (electron-builder needs it at
# build time); the 4K icon.png is regenerable from icon-source.png via
# app/build/make-icon.mjs, so it stays out of history.
app/build/icon.png
app/build/_preview.png

# Logs / OS cruft
*.log
.DS_Store
Thumbs.db

# Archives / generated design output (e.g. Stitch UI exports)
*.zip
stitch_*/

# Claude config (not version-controlled)
.claude/
