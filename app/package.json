{
  "name": "vessel-app",
  "version": "1.0.0",
  "description": "Vessel — local uncensored character roleplay desktop app.",
  "main": "out/main/index.js",
  "author": "Pratik",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "sharp": "^0.35.3",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.vessel.app",
    "productName": "Vessel",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../src",
        "to": "backend/src",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../Modelfile",
        "to": "backend/Modelfile"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Vessel"
    }
  }
}
